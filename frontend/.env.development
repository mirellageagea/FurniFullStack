# Used only when running "npm run dev" (Vite's dev server on :5173).
# Points at FurniAPI running separately in Visual Studio, for hot-reload development.
VITE_API_URL=https://localhost:5001

# Same Google OAuth Client ID as FurniAPI's appsettings.json -> Google:ClientId
# Get one at https://console.cloud.google.com/apis/credentials (OAuth client ID,
# type "Web application", add http://localhost:5173 and https://localhost:5001
# under "Authorized JavaScript origins").
VITE_GOOGLE_CLIENT_ID=792344093384-e0c8hfi3d6vuss0k3defmc7ncvn15qjt.apps.googleusercontent.com
