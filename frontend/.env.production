# Used only when running "npm run build". Left empty on purpose: once the build
# is copied into FurniAPI/wwwroot, the site and the API are served from the
# exact same origin, so requests can just be relative paths ("/api/...").
VITE_API_URL=

# Same Google OAuth Client ID as FurniAPI's appsettings.json -> Google:ClientId
VITE_GOOGLE_CLIENT_ID=792344093384-e0c8hfi3d6vuss0k3defmc7ncvn15qjt.apps.googleusercontent.com
